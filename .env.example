# Copie este arquivo para .env e preencha suas chaves
# cp .env.example .env

# Provider LLM: "claude" ou "openai"
LLM_PROVIDER=claude

# Anthropic (necessario se LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (necessario se LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Modelo opcional (sobrescreve o default do provider)
# LLM_MODEL=claude-haiku-4-5
# LLM_MODEL=gpt-4o-mini
